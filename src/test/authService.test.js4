import { describe, it, expect, beforeEach, vi } from 'vitest'

// Mock de localStorage
const localStorageMock = (() => {
  let store = {}
  return {
    getItem: (key) => store[key] ?? null,
    setItem: (key, value) => { store[key] = value },
    removeItem: (key) => { delete store[key] },
    clear: () => { store = {} },
  }
})()

Object.defineProperty(global, 'localStorage', { value: localStorageMock })

const decodeJWT = (token) => {
  try {
    const base64Url = token.split('.')[1]
    const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/')
    const jsonPayload = decodeURIComponent(
      atob(base64).split('').map((c) => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join('')
    )
    return JSON.parse(jsonPayload)
  } catch {
    return null
  }
}

const isTokenExpired = (token) => {
  if (!token) return true
  const decoded = decodeJWT(token)
  if (!decoded) return true
  return decoded.exp * 1000 < Date.now()
}

const getUser = () => {
  const u = localStorage.getItem('user')
  return u ? JSON.parse(u) : null
}

const isAdmin = (user) => user?.role === 'ADMIN' || user?.rol === 'ADMIN'

describe('authService — getUser', () => {
  beforeEach(() => localStorage.clear())

  it('devuelve null si no hay usuario', () => {
    expect(getUser()).toBeNull()
  })

  it('devuelve el usuario guardado', () => {
    localStorage.setItem('user', JSON.stringify({ id: 1, name: 'María' }))
    expect(getUser()).toEqual({ id: 1, name: 'María' })
  })
})

describe('authService — isAdmin', () => {
  it('devuelve true si role es ADMIN', () => {
    expect(isAdmin({ role: 'ADMIN' })).toBe(true)
  })

  it('devuelve true si rol es ADMIN', () => {
    expect(isAdmin({ rol: 'ADMIN' })).toBe(true)
  })

  it('devuelve false si no es admin', () => {
    expect(isAdmin({ role: 'USER' })).toBe(false)
  })

  it('devuelve false si es null', () => {
    expect(isAdmin(null)).toBe(false)
  })
})

describe('authService — isTokenExpired', () => {
  it('devuelve true si no hay token', () => {
    expect(isTokenExpired(null)).toBe(true)
  })

  it('devuelve true si el token es inválido', () => {
    expect(isTokenExpired('token.invalido.xxx')).toBe(true)
  })
})